{
    "name": "thatobabusi/laravel-repository",
    "description": "A Laravel 13-compatible repository pattern implementation with Eloquent, criteria-based filtering, and Artisan generators.",
    "keywords": ["thatobabusi", "laravel", "repository", "pattern", "criteria", "eloquent"],
    "homepage": "https://github.com/thatobabusi/laravel-repository",
    "license": "MIT",
    "authors": [
        {
            "name": "Thato Babusi",
            "email": "thatobabusi@yahoo.com",
            "homepage": "https://thatobabusi.co.za/blog"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11|^12|^13",
        "illuminate/database": "^11|^12|^13",
        "illuminate/console": "^11|^12|^13"
    },
    "require-dev": {
        "orchestra/testbench": "^9|^10",
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Laravel\\Repository\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laravel\\Repository\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laravel\\Repository\\LaravelRepositoryServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
